{
  "name": "@ovrsr/openclaw-fpp-trust",
  "version": "1.2.10",
  "description": "OpenClaw plugin: agent-to-agent trust graph and constitutional handshake for the Freedom Preserving Protocol",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": "ovrsr",
  "repository": {
    "type": "git",
    "url": "https://github.com/ovrsr/freedom-preserving-protocol",
    "directory": "plugin-trust"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "bundledDependencies": [
    "@ovrsr/fpp-protocol-core",
    "@ovrsr/fpp-trust-core"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle:deps": "npx tsx ../scripts/bundle-workspace-deps.ts --package plugin-trust",
    "prepack": "npm run build && npm run bundle:deps",
    "typecheck": "tsc -p tsconfig.json --noEmit --declaration false --declarationMap false",
    "test": "tsx --test src/**/*.test.ts pack-bundle.test.ts",
    "test:coverage": "c8 tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "@ovrsr/fpp-protocol-core": "1.0.2",
    "@sinclair/typebox": "^0.34.0",
    "@ovrsr/fpp-trust-core": "1.0.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^10.1.3",
    "openclaw": "^2026.6.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.19"
  }
}
