{
  "name": "@ovrsr/fpp-tool-proxy",
  "version": "0.1.0",
  "description": "Shared MCP/sidecar tool proxy for FPP enforcement-core",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/", "src/", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit --declaration false --declarationMap false",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@ovrsr/fpp-enforcement-core": "1.0.0",
    "@ovrsr/fpp-protocol-core": "1.0.0"
  },
  "devDependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.19"
  }
}
